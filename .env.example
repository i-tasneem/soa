# Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub - it's in .gitignore

# ── ANGEL ONE SMARTAPI CREDENTIALS ──────────────────────
# Get these from: https://smartapi.angelbroking.com
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_4_digit_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ── SERVER CONFIGURATION ────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── DATABASE ────────────────────────────────────────────
# Database path will be created automatically in data/ directory
DATABASE_PATH=./data/soa-trader.db

# ── TRADING PREFERENCES ────────────────────────────────
TRADING_DEFAULT_LOTS=15
TRADING_DEFAULT_TARGET=25
TRADING_DEFAULT_STOP_LOSS=20
TRADING_DEFAULT_MONTHLY_GOAL=35000

# ── MONITORING ────────────────────────────────────────
# Enable detailed monitoring and metrics logging
ENABLE_MONITORING=true
METRICS_LOG_INTERVAL=60000

# ── SECURITY ───────────────────────────────────────────
# CORS whitelist (comma-separated URLs)
CORS_WHITELIST=http://localhost:3000,http://192.168.1.1:3000
