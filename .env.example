# ============================================================
# SOA Trader v7 — Environment Configuration
# Copy this file to .env and fill in your credentials
# ============================================================

# ── BROKER SELECTION ─────────────────────────────────────────
# Supported: 'angel' or 'dhan'
BROKER_TYPE=angel

# ── ANGEL ONE CREDENTIALS (required if BROKER_TYPE=angel) ──
ANGEL_API_KEY=your_angel_api_key_here
ANGEL_CLIENT_ID=your_angel_client_id_here
ANGEL_PASSWORD=your_angel_password_here
ANGEL_TOTP_SECRET=your_angel_totp_secret_here
ANGEL_BASE_URL=https://apiconnect.angelone.in

# ── DHAN CREDENTIALS (required if BROKER_TYPE=dhan) ──────────
DHAN_ACCESS_TOKEN=your_dhan_access_token_here
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_BASE_URL=https://api.dhan.co

# ── REDIS CONFIGURATION ────────────────────────────────────
# Set REDIS_ENABLED=true to enable Redis caching
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── POLLING INTERVALS (milliseconds) ─────────────────────────
LTP_INTERVAL=2000
CHAIN_INTERVAL=5000
WS_THROTTLE_MS=5000

# ── DATABASE ───────────────────────────────────────────────
DB_PATH=./data/trading.db

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
